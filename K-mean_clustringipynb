    {
      "cell_type": "code",
      "source": [
        "#k-means clustring example group customers\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "from sklearn.cluster import KMeans\n"
      ],
      "metadata": {
        "id": "UlX9PksZbM9e"
      },
      "execution_count": 3,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "#sample data\n",
        "data={\n",
        "    'Annual_Income':[15,16,17,45,46,48,85,86,88],\n",
        "    'Spending_score':[39,40,42,60,62,63,20,25,22]\n",
        "}"
      ],
      "metadata": {
        "id": "ZFOBvXrObPfI"
      },
      "execution_count": 4,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "df=pd.DataFrame(data)"
      ],
      "metadata": {
        "id": "l4dH7224cMIf"
      },
      "execution_count": 5,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "#create k-mean model\n",
        "kmean = KMeans(n_clusters=3,random_state=42)\n",
        "df['cluster']= kmean.fit_predict(df)"
      ],
      "metadata": {
        "id": "v2jEsMBhcQVv"
      },
      "execution_count": 15,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "#centroids\n",
        "centroids =kmean.cluster_centers_"
      ],
      "metadata": {
        "id": "ndRzDyMRcsJh"
      },
      "execution_count": 16,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "#plot clusters\n",
        "plt.scatter(df['Annual_Income'],df['Spending_score'],c=df['cluster'],cmap='rainbow')\n",
        "plt.scatter(centroids[:,0],centroids[:,1],color='black',marker='x',s=100)#centroids\n",
        "plt.xlabel('Annual Income')\n",
        "plt.ylabel('Spending Score')\n",
        "plt.title(\"K-Mean clustring example\")\n",
        "plt.show()"
      ],
